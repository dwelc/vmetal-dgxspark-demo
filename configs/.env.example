# vmetal-dgxspark-demo configuration
# Copy to .env and adjust values for your environment.
# All scripts source .env from the repo root if it exists.

# ---------------------------------------------------------------------------
# DGX Spark host networking
# ---------------------------------------------------------------------------

# The DGX Spark's outbound NIC (check: ip route show default)
LAN_INTERFACE=enP7s7

# The DGX Spark's LAN IP — must be reachable from k3s nodes
LAN_IP=192.168.1.101

# ---------------------------------------------------------------------------
# Provisioning bridge
# ---------------------------------------------------------------------------

PROVISION_BRIDGE=br-provision

# IP assigned to the bridge on the DGX Spark host.
# Sushy-tools and the OS image server listen here.
PROVISION_BRIDGE_IP=172.22.0.1

# Subnet for the provisioning network.
PROVISION_CIDR=172.22.0.0/24
PROVISION_GATEWAY=172.22.0.1

# IP used in BareMetalHost Redfish addresses.
# Must be the LAN IP so Ironic (on the k3s cluster) can reach sushy-tools.
PROVISION_IP=${LAN_IP}

# First assignable VM IP — .1 is the bridge, .2 is the DHCP VIP, .3 is Ironic
VM_IP_START=172.22.0.11

# ---------------------------------------------------------------------------
# VXLAN tunnel
# ---------------------------------------------------------------------------

# The k3s node where Metal3/Ironic will run (must be x86)
VXLAN_REMOTE_IP=192.168.1.102
VXLAN_REMOTE_DEV=enp2s0

# Local device for VXLAN encapsulation
VXLAN_LOCAL_DEV=${LAN_INTERFACE}

# VXLAN ID and port
VXLAN_ID=100
VXLAN_DSTPORT=4789

# ---------------------------------------------------------------------------
# k3s cluster
# ---------------------------------------------------------------------------

# URL of the k3s server to join
K3S_SERVER_URL=https://192.168.1.102:6443

# Token for k3s agent join (get from: sudo cat /var/lib/rancher/k3s/server/node-token)
K3S_TOKEN=

# ---------------------------------------------------------------------------
# Sushy Tools (Redfish BMC emulator)
# ---------------------------------------------------------------------------

SUSHY_PORT=8000
SUSHY_LIBVIRT_URI=qemu:///system
SUSHY_LISTEN_IP=
SUSHY_VENV=/opt/sushy-tools
SUSHY_CONF_DIR=/etc/sushy-tools

# ---------------------------------------------------------------------------
# BMC credentials
# ---------------------------------------------------------------------------

BMC_USERNAME=admin
BMC_PASSWORD=password

# ---------------------------------------------------------------------------
# VM profiles
# ---------------------------------------------------------------------------

SMALL_VM_COUNT=3
SMALL_VM_VCPUS=2
SMALL_VM_RAM_MB=4096
SMALL_VM_DISK_GB=40
SMALL_VM_NAME_PREFIX=vmetal-small

LARGE_VM_COUNT=2
LARGE_VM_VCPUS=4
LARGE_VM_RAM_MB=8192
LARGE_VM_DISK_GB=80
LARGE_VM_NAME_PREFIX=vmetal-large

VM_IMAGE_DIR=/var/lib/libvirt/images

# ---------------------------------------------------------------------------
# OS Image cache server
# ---------------------------------------------------------------------------

IMAGE_SERVER_PORT=9000
IMAGE_CACHE_DIR=/srv/os-images

# arm64 Ubuntu image for DGX Spark VMs
UBUNTU_IMAGE_URL=https://cloud-images.ubuntu.com/minimal/releases/noble/release/ubuntu-24.04-minimal-cloudimg-arm64.img
UBUNTU_IMAGE_FILE=ubuntu-24.04-minimal-cloudimg-arm64.img
